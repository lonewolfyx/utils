{
    "compilerOptions": {
        "target": "ESNext",
        "baseUrl": "./",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "resolveJsonModule": true,
        "allowImportingTsExtensions": true,
        "strict": true,
        "noEmit": true,
        "stripInternal": true,
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
